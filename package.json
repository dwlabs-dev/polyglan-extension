{
  "name": "polyglan-extension",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:front\" \"npm run dev:api\"",
    "dev:front": "cd front && npm run dev",
    "dev:api": "cd api && npm run dev",
    "install:all": "cd api && npm install && cd ../front && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}